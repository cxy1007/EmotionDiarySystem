<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
      黑夜模式全局主题（柔和深色，降低刺眼感）
      说明：
      1. 与日间主题保持统一风格
      2. 仅覆盖夜间下核心配色
    -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 夜间主色：柔和偏亮蓝紫 -->
        <item name="colorPrimary">#A9B3F5</item>
        <item name="colorOnPrimary">#1D2230</item>

        <!-- 夜间次级色：柔和青绿 -->
        <item name="colorSecondary">#8FD0C1</item>
        <item name="colorOnSecondary">#1D2230</item>

        <!-- 背景与表面 -->
        <item name="android:colorBackground">#161A24</item>
        <item name="colorSurface">#1D2230</item>
        <item name="colorOnSurface">#E6EAF3</item>

        <!-- 状态栏与导航栏（深色背景） -->
        <item name="android:statusBarColor">#161A24</item>
        <item name="android:navigationBarColor">#161A24</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <!-- 标题文本样式（夜间） -->
    <style name="TextStyle.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">#F1F4FB</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- 正文文本样式（夜间） -->
    <style name="TextStyle.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">#D6DBE8</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- 按钮样式（夜间） -->
    <style name="WidgetStyle.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#1D2230</item>
        <item name="backgroundTint">#A9B3F5</item>
    </style>

    <!-- 输入框样式（夜间） -->
    <style name="WidgetStyle.InputField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#727AA0</item>
        <item name="hintTextColor">#A7AEC4</item>
        <item name="android:textColorHint">#A7AEC4</item>
    </style>

    <!-- 输入框内部文本样式（夜间） -->
    <style name="TextStyle.InputText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">#E6EAF3</item>
        <item name="android:textColorHint">#A7AEC4</item>
    </style>

</resources>