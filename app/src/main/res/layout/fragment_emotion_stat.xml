<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F7FAFC">

        <!-- 顶部导航栏（带月份切换） -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#FFFFFF">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/arrow_up_float"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:rotation="-90"
                android:contentDescription="上月"/>

            <TextView
                android:id="@+id/tv_month_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="2024年5月"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D3748"/>

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/arrow_up_float"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:rotation="90"
                android:contentDescription="下月"/>
        </LinearLayout>

        <!-- 空状态提示 -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="64dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无情感数据，快去记录第一篇日记吧"
                android:textSize="16sp"
                android:textColor="#718096"
                android:gravity="center"/>
        </LinearLayout>

        <!-- 统计概览卡片（保持不变） -->
        <LinearLayout
            android:id="@+id/layout_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总日记数"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_total_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#2D3748"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginLeft="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="积极日记"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_positive_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#276749"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="中性日记"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_neutral_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#718096"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginLeft="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="消极日记"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_negative_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#702459"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 情感分布环形图（替换原有统计图） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F7FAFC"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="情感分布图"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <com.example.emotiondiarysystem.ui.emotion.EmotionRingChartView
                    android:id="@+id/emotion_ring_chart"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 情绪关键词云（替换原有趋势图） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F7FAFC"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的高频情绪词"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <com.example.emotiondiarysystem.ui.emotion.EmotionKeywordCloudView
                    android:id="@+id/emotion_keyword_cloud"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 心情语录推荐（保持不变） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="心情语录推荐"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_quote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="「生活中不缺少美，缺少的是发现美的眼睛。」"
                    android:textSize="15sp"
                    android:textColor="#4A5568"
                    android:textStyle="italic"
                    android:lineSpacingExtra="6dp"
                    android:padding="12dp"
                    android:background="#F7FAFC"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tv_quote_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— 罗丹"
                        android:textSize="12sp"
                        android:textColor="#A0AEC0"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 本周情感趋势 + 情绪建议（保持不变） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本周情感趋势"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_weekly_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无数据，开始写日记后查看趋势"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="情绪建议"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_advice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="每天记录日记可以帮助您更好地了解自己的情绪变化哦"
                    android:textSize="14sp"
                    android:textColor="#718096"
                    android:lineSpacingExtra="4dp"
                    android:padding="12dp"
                    android:background="#EDF2F7"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>