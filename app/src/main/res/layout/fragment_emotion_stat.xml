<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F7FAFC">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#FFFFFF">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="情感统计"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2D3748"/>
        </LinearLayout>

        <!-- 统计概览卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总日记数"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_total_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#2D3748"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginLeft="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="积极日记"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_positive_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#276749"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="中性日记"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_neutral_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#718096"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="16dp"
                    android:layout_marginLeft="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="消极日记"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:id="@+id/tv_negative_diary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#702459"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 情感分析结果 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="情感分析结果"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_emotion_analysis_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无分析结果，请先记录几篇日记"
                    android:textSize="14sp"
                    android:textColor="#718096"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 周情感统计图 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="周情感统计图"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <com.example.emotiondiarysystem.ui.emotion.WeekBarChartView
                    android:id="@+id/week_bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

                <TextView
                    android:id="@+id/tv_week_no_data"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:gravity="center"
                    android:text="本周暂无日记数据"
                    android:textSize="14sp"
                    android:textColor="#A0AEC0"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 月情感趋势图 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="月情感趋势图"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <com.example.emotiondiarysystem.ui.emotion.MonthLineChartView
                    android:id="@+id/month_line_chart"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

                <TextView
                    android:id="@+id/tv_month_no_data"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:gravity="center"
                    android:text="本月暂无日记数据"
                    android:textSize="14sp"
                    android:textColor="#A0AEC0"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 心情语录推荐 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="心情语录推荐"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_quote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="「生活中不缺少美，缺少的是发现美的眼睛。」"
                    android:textSize="15sp"
                    android:textColor="#4A5568"
                    android:textStyle="italic"
                    android:lineSpacingExtra="6dp"
                    android:padding="12dp"
                    android:background="#F7FAFC"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tv_quote_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— 罗丹"
                        android:textSize="12sp"
                        android:textColor="#A0AEC0"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 本周情感趋势 + 情绪建议 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本周情感趋势"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_weekly_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无数据，开始写日记后查看趋势"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="情绪建议"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_advice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="每天记录日记可以帮助您更好地了解自己的情绪变化哦"
                    android:textSize="14sp"
                    android:textColor="#718096"
                    android:lineSpacingExtra="4dp"
                    android:padding="12dp"
                    android:background="#EDF2F7"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>