<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF"
    android:elevation="2dp">

    <!-- 顶部：日期和回收站标签 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-05-04"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#4ECDC4"/>

        <TextView
            android:id="@+id/tv_recycle_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="回收站"
            android:textSize="12sp"
            android:textColor="#F56565"
            android:background="#FEF2F2"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_emotion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="积极"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="#48BB78"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- 标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="日记标题"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2D3748"
        android:layout_marginTop="8dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- 内容 -->
    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="日记内容"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginTop="4dp"
        android:maxLines="3"
        android:ellipsize="end"/>

    <!-- 标签栏 -->
    <LinearLayout
        android:id="@+id/layout_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tv_tag_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="晴天"
            android:textSize="12sp"
            android:textColor="#4ECDC4"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_tag_mood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开心"
            android:textSize="12sp"
            android:textColor="#4ECDC4"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_tag_activity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="工作"
            android:textSize="12sp"
            android:textColor="#4ECDC4"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
