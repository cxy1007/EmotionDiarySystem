<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!-- 日期标签 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_diary_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="29"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4ECDC4"/>

        <TextView
            android:id="@+id/tv_diary_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4月"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            android:layout_marginStart="8dp"/>

        <TextView
            android:id="@+id/tv_diary_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="电影"
            android:textSize="16sp"
            android:textColor="#2D3748"
            android:layout_marginStart="12dp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- 内容 -->
    <TextView
        android:id="@+id/tv_diary_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="好看"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:ellipsize="end"/>

    <!-- 标签栏 -->
    <LinearLayout
        android:id="@+id/layout_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tv_tag_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="晴天"
            android:textSize="12sp"
            android:textColor="#4ECDC4"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_tag_mood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开心"
            android:textSize="12sp"
            android:textColor="#4ECDC4"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_tag_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="电影"
            android:textSize="12sp"
            android:textColor="#4ECDC4"
            android:background="@drawable/bg_tag"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB"
        android:layout_marginTop="12dp"/>

</LinearLayout>
