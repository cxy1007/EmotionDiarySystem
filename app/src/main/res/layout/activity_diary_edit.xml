<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7FAFC"
    android:fitsSystemWindows="true">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="写日记"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:gravity="center"
            android:layout_marginRight="48dp"/>

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"/>

    <!-- 日期显示 -->
    <TextView
        android:id="@+id/tv_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2026-04-14"
        android:textSize="14sp"
        android:textColor="#888888"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"/>

    <!-- 日记内容输入 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="今天发生了什么？记录一下吧..."
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#E2E8F0"
            app:hintTextColor="#888888">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="200dp"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top"
                android:textSize="16sp"
                android:textColor="#2D3748"
                android:padding="16dp"/>

        </com.google.android.material.textfield.TextInputLayout>

    </ScrollView>

    <!-- 情感分析结果区域 -->
    <LinearLayout
        android:id="@+id/layout_emotion_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#F7FAFC"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="情感分析："
            android:textSize="14sp"
            android:textColor="#888888"/>

        <TextView
            android:id="@+id/tv_emotion_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="积极"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#48BB78"/>

    </LinearLayout>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_analyze"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="分析情感"
            android:textSize="14sp"
            android:textColor="#2D3748"
            android:backgroundTint="#E2E8F0"
            android:layout_marginRight="8dp"/>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="保存日记"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2D3748"
            android:layout_marginLeft="8dp"/>

    </LinearLayout>

</LinearLayout>
