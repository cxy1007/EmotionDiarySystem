<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="16dp">

    <!-- 正面：日记内容 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_front"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- 日期显示区域 - 统一高度46dp，和引导卡片一致 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal">

                <!-- 日期数字 -->
                <TextView
                    android:id="@+id/tv_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#7BA7D9"/>

                <!-- 月份（不显示年份） -->
                <TextView
                    android:id="@+id/tv_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4月"
                    android:textSize="16sp"
                    android:textColor="#757575"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="6dp"/>

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:background="#E5E7EB"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <!-- 标题和内容区域 - 固定高度120dp，和引导卡片一致 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="vertical"
                android:gravity="center">

                <!-- 日记标题 - 如果有就显示 -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="今天的日记"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone"/>

                <!-- 日记内容预览 -->
                <TextView
                    android:id="@+id/tv_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="今天天气很好，去公园散步了..."
                    android:textSize="18sp"
                    android:textColor="#374151"
                    android:lineSpacingMultiplier="1.6"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- 心情日签按钮 - 和引导卡片按钮位置对齐 -->
            <Button
                android:id="@+id/btn_mood_tag"
                android:layout_width="180dp"
                android:layout_height="48dp"
                android:text="心情日签"
                android:textSize="16sp"
                android:textColor="#757575"
                android:background="@android:color/transparent"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 背面：心情日签 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- 日期显示区域 - 统一高度46dp，和正面一致 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal">

                <!-- 日期数字 -->
                <TextView
                    android:id="@+id/tv_day_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#7BA7D9"/>

                <!-- 月份（不显示年份） -->
                <TextView
                    android:id="@+id/tv_month_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4月"
                    android:textSize="16sp"
                    android:textColor="#757575"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="6dp"/>

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:background="#E5E7EB"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <!-- 心情日签语录 - 固定高度120dp，居中显示，和正面正文区域一致 -->
            <TextView
                android:id="@+id/tv_mood_quote"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:text="「每一个不曾起舞的日子，都是对生命的辜负。」"
                android:textSize="18sp"
                android:textColor="#374151"
                android:lineSpacingMultiplier="1.6"
                android:gravity="center"
                android:maxLines="3"
                android:ellipsize="end"/>

            <!-- 语录作者 -->
            <TextView
                android:id="@+id/tv_mood_quote_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— 尼采"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="8dp"/>

            <!-- 返回按钮 - 和正面心情日签按钮位置对齐 -->
            <Button
                android:id="@+id/btn_flip_back"
                android:layout_width="180dp"
                android:layout_height="48dp"
                android:text="返回"
                android:textSize="16sp"
                android:textColor="#757575"
                android:background="@android:color/transparent"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>